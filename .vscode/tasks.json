{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter: web for iPad (interactive terminal)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/run_web_for_ipad.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "problemMatcher": []
    }
  ]
}
